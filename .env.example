# Copy to `.env` and fill in. `.env` is gitignored: never commit real values.

# Apify API token: required for the LinkedIn + X crawl lanes.
# Get one at https://console.apify.com/account/integrations
APIFY_TOKEN=

# RSS uses free feedparser (no key). Email uses the Gmail MCP (configured in
# .mcp.json, not here). See docs/setup.md for the full setup.
